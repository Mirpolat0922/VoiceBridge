VOICEBRIDGE_BOT_TOKEN=replace-me
VOICEBRIDGE_LOG_LEVEL=INFO
VOICEBRIDGE_DB_PATH=voicebridge.db
VOICEBRIDGE_STORAGE_DIR=data

VOICEBRIDGE_DEFAULT_SOURCE_LANGUAGE=ru
VOICEBRIDGE_DEFAULT_TARGET_LANGUAGE=ru
VOICEBRIDGE_DEFAULT_REPLY_MODE=text_only

VOICEBRIDGE_GROQ_API_KEY=replace-me
VOICEBRIDGE_GROQ_MODEL_NAME=llama-3.3-70b-versatile
VOICEBRIDGE_GROQ_ENDPOINT=https://api.groq.com/openai/v1/chat/completions
VOICEBRIDGE_GROQ_MAX_ATTEMPTS=2
VOICEBRIDGE_GROQ_RETRY_BASE_DELAY_SECONDS=1.0
VOICEBRIDGE_GROQ_MAX_COMPLETION_TOKENS=300

VOICEBRIDGE_WHISPER_MODEL_SIZE=small
VOICEBRIDGE_WHISPER_DEVICE=auto
VOICEBRIDGE_WHISPER_COMPUTE_TYPE=int8
VOICEBRIDGE_ASR_PROVIDER_UZ=nemo_uzbek
VOICEBRIDGE_ASR_PROVIDER_RU=faster_whisper
VOICEBRIDGE_ASR_PROVIDER_EN=faster_whisper
VOICEBRIDGE_NEMO_UZBEK_MODEL_NAME=nvidia/stt_uz_fastconformer_hybrid_large_pc
